# ====================================================================
# ZEB-ROI Chatbot — 환경 변수 템플릿
# ====================================================================
# 사용법:
#   1. 이 파일을 .env로 복사: cp .env.example .env
#   2. .env 파일에 실제 API 키 채워넣기
#   3. .env는 절대 GitHub에 커밋하지 말 것 (.gitignore에 등록됨)
# ====================================================================

# --- Claude API (Anthropic) ---
# 발급: https://console.anthropic.com/settings/keys
# 권장 충전: $5 (약 7,000원)
ANTHROPIC_API_KEY=sk-ant-api03-여기에_실제_키_입력

# --- OpenAI API (임베딩 전용) ---
# 발급: https://platform.openai.com/api-keys
# 사용 모델: text-embedding-3-small (한글 임베딩에 가장 저렴)
# 권장 충전: $5 (약 7,000원) — 인덱싱 1회당 약 100원
OPENAI_API_KEY=sk-proj-여기에_실제_키_입력

# --- 비용 안전장치 (코드에서 참조) ---
# IP당 시간당 호출 횟수 제한
RATE_LIMIT_PER_HOUR=30

# 모델 선택 (기본값 유지 권장)
CLAUDE_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=text-embedding-3-small

# --- 데이터 경로 (기본값 유지 권장) ---
POLICY_DOCS_DIR=./data/policy_docs
CHROMA_DB_DIR=./data/chroma_db
PRICE_DB_PATH=./data/policy_docs/07_조달청_단가DB.xlsx
INDIRECT_COST_PATH=./data/policy_docs/08_조달청_간접공사비_2026.xlsx
